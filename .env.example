# ——— Página ———
MONITOR_TITLE=Libras Status
MONITOR_TAGLINE=Monitoramento em tempo real — API, Huet, Tils, Worker e infra
MONITOR_PUBLIC_URL=http://localhost:3100
POLL_INTERVAL_MS=30000
REQUEST_TIMEOUT_MS=8000

# Protege /api/* (opcional). Envie Authorization: Bearer <key> ou header x-monitor-api-key
# MONITOR_API_KEY=

# ——— Aplicações ———
API_BASE_URL=http://localhost:7777
API_HEALTH_PATH=/health
API_READY_PATH=/ready

WORKER_HEALTH_URL=http://localhost:9099/health

HUET_BASE_URL=http://localhost:3000
HUET_HEALTH_PATH=/health.txt

TILS_BASE_URL=http://localhost:5173
TILS_HEALTH_PATH=/

# ——— Infra (alinhar com api/.env) ———
RABBITMQ_MANAGEMENT_URL=http://localhost:15672
RABBITMQ_MANAGEMENT_USER=guest
RABBITMQ_MANAGEMENT_PASSWORD=guest

# Host local (no Docker da API o endpoint é libras-se-storage:9000)
STORAGE_HEALTH_URL=http://localhost:9000/minio/health/live

# Mesmo DATABASE_URL da API; /ready só testa DB se HEALTHCHECK_DEEP_ENABLED=true na API
DATABASE_URL=postgresql://docker:docker@localhost:5432/docker

# REDIS_URL=  # só se a API tiver REDIS_URL configurado

# ——— Slack (backend Next.js) ———
SLACK_ALERTS_ENABLED=false
SLACK_WEBHOOK_URL=
# ou bot:
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=C01234567
# SLACK_MENTION_ON_DOWN=<!channel>

# Cron externo: GET/POST /api/cron/check com Authorization: Bearer <CRON_SECRET>
CRON_SECRET=change-me-in-production
